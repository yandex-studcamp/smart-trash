APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
APP_CORS_ALLOW_ORIGINS=*
APP_MAX_UPLOAD_SIZE_BYTES=10485760
APP_UPLOADS_DIR=data/uploads

YOLO_MODEL=yolo26m-cls.pt

PIPELINE_SPOTTER_WINDOW_SIZE=8
PIPELINE_SPOTTER_TRUE_RATIO_THRESHOLD=0.6
PIPELINE_SPOTTER_CONFIG=src/config/spotter_patchcore.yaml
PIPELINE_SPOTTER_CHECKPOINT=src/spotter/meta/patchcore.ckpt
PIPELINE_SPOTTER_DEVICE=auto
PIPELINE_CLASSIFIER_WEIGHTS=src/classifier/weights/best.pt
PIPELINE_CLASSIFIER_DEVICE=
PIPELINE_CLASSIFIER_IMGSZ=224
PIPELINE_CLASSIFIER_CONF_THRESHOLD=0.3
PIPELINE_CROP_PADDING=0.10
PIPELINE_CROP_MIN_PADDING=6
PIPELINE_SAVE_DEBUG_ARTIFACTS=true
PIPELINE_DEBUG_DIR=runs/runtime_pipeline
PIPELINE_BACKGROUND_FILL=black
PIPELINE_CLEAN_MODE=strict
PIPELINE_BACKGROUND_REF=
PIPELINE_COMMAND_COOLDOWN_FRAMES=0
